# This input file is an exmple for mu=2 and eps=1 simulation

variable t index 100000
units 	 lj
atom_style	hybrid dipole sphere

lattice sc 0.381971863
# this give phi = 0.20

region		box1 block 0 20 0 20 0 20
create_box	1 box1
create_atoms	1 box

velocity all create 1.0 4928459  dist gaussian

#read_data 	 lmptest.data
timestep 	 0.00100

#set mu
set	group all charge 0.0
set	group all dipole 0.0 0.0 2.0

mass 	 1 1.0
pair_style 	 hybrid/overlay table spline 11000 ewald lj/cut/dipole/long 0 5
pair_coeff       * * table colloid-eps1.table colloid 5
pair_coeff	 * * lj/cut/dipole/long 0.0 1.0

kspace_style	 ewald/dipole 1.0E-2
neighbor 	 0.3 bin
neigh_modify 	 delay 0 every 100 check no


#OUTPUT
dump 	 lmptest.xyz all xyz 50 lmptest.xyz
dump 	 myxyz all custom 10000 mu2_eps1.xyz id type x y z

fix 	 1 all nvt temp 1.000000 1.000000 1
thermo 	 10
thermo_style 	 custom elapsed pe ke etotal press temp

restart 100 restartA.lmp restartB.lmp

run      $t
write_restart restart_final.lmp